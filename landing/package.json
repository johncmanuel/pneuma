{
  "name": "landing",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "sync:icons": "bun run --cwd .. sync:icons",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "predev": "bun run sync:icons && bun run scripts/copy-screenshots.ts",
    "prebuild": "bun run sync:icons && bun run scripts/copy-screenshots.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "@lucide/svelte": "*"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.50.2"
  }
}
