{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@pneuma/shared": ["./packages/shared/src/index.ts"],
      "@pneuma/shared/*": ["./packages/shared/src/*"],
      "@pneuma/ui": ["./packages/ui/src/lib/index.ts"],
      "@pneuma/ui/*": ["./packages/ui/src/lib/*", "./packages/ui/src/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["packages/shared/src/**/*.ts", "packages/ui/src/**/*.ts"]
}
